APP_ENV=production
JWT_SECRET={{ vault_multica_jwt_secret }}
ALLOWED_EMAILS={{ multica_allowed_emails }}
FRONTEND_ORIGIN=http://{{ neon_ip }}:3000
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port | default(587) }}
SMTP_USERNAME={{ smtp_user }}
SMTP_PASSWORD={{ vault_smtp_password }}
# Multica reuses RESEND_FROM_EMAIL as the From header even in SMTP mode
RESEND_FROM_EMAIL={{ smtp_from | default('neon@flefevre.fr') }}
